# Book Finder Agent - Environment Configuration Template
# Copy this file to .env and fill in with your actual values
# See CONFIG_REFERENCE.md for detailed documentation of each parameter

################################################################################
# DATABASE CONFIGURATION
################################################################################

# PostgreSQL/AlloyDB server hostname or IP
POSTGRES_HOST=localhost

# PostgreSQL server port (default: 5432)
POSTGRES_PORT=5432

# Database name
POSTGRES_DB=book_finder_db

# PostgreSQL username (NOT the superuser 'postgres' for production)
POSTGRES_USER=postgres

# PostgreSQL password - MUST BE CHANGED FOR PRODUCTION
# Use a strong password: 20+ characters, mixed case, symbols
POSTGRES_PASSWORD=change_me_in_production

################################################################################
# GOOGLE CLOUD CONFIGURATION
################################################################################

# Google Cloud Project ID (e.g., "my-company-prod-123")
GCLOUD_PROJECT_ID=your-gcp-project-id

# Default Google Cloud region for API calls
# Valid: us-central1, us-west1, europe-west1, asia-southeast1
GCLOUD_LOCATION=us-central1

# Path to Google Cloud service account key JSON file
# Download from GCP Console > Service Accounts
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Google Cloud Project ID for PubSub (can be same as GCLOUD_PROJECT_ID)
PUBSUB_PROJECT_ID=your-gcp-project-id

# PubSub topic name for streaming responses
PUBSUB_TOPIC_NAME=book-finder-responses

################################################################################
# APPLICATION CONFIGURATION
################################################################################

# Flask environment
# development: enables auto-reload, debug mode
# production: disables debug, uses production error handling
FLASK_ENV=development

# Flask secret key for session encryption and CSRF protection
# MUST be changed for production (32+ characters, random)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# HTTP port the agent listens on
PORT=5000

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# DEBUG: very verbose (high disk I/O)
# INFO: standard production level
LOG_LEVEL=INFO

################################################################################
# GUNICORN (PRODUCTION SERVER) CONFIGURATION
################################################################################

# Number of Gunicorn worker processes
# Formula: (2 × CPU_COUNT) + 1
# Example: for 4-core machine: 9
WORKER_COUNT=4

# Number of threads per worker (with gthread worker class)
# Total concurrent requests = WORKER_COUNT × WORKER_THREADS_COUNT
WORKER_THREADS_COUNT=2

# Worker timeout in seconds (prevent hung requests)
# Range: 30-600
WORKER_TIMEOUT=120

# Number of requests before worker is recycled (memory leak mitigation)
MAX_REQUEST_TO_WORKER_RESTART=1000

# Graceful shutdown timeout for workers (allow in-flight requests to finish)
WORKER_GRACEFUL_TIMEOUT=30

################################################################################
# LLM CONFIGURATION
################################################################################

# LLM model to use for response generation
# Options: gemini-2.0-flash-001, gemini-1.5-pro, gemini-1.5-flash
LLM_MODEL_NAME=gemini-2.0-flash-001

# Temperature controls randomness in outputs
# Range: 0.0 (deterministic) to 2.0 (very creative)
# Recommended: 0.3-0.7 for book recommendations
LLM_TEMPERATURE=0.7

# Maximum tokens (words) in LLM response
# Range: 10-8000
# Typical: 512 (short) to 2048 (detailed)
LLM_MAX_TOKENS=1024

# Nucleus sampling parameter (top-p)
# Range: 0.0-1.0
# Higher = more diverse outputs
LLM_TOP_P=0.95

# Enable streaming responses to clients via PubSub
ENABLE_STREAMING=true

################################################################################
# RETRIEVAL CONFIGURATION
################################################################################

# Number of top-ranked books to include in response
# Range: 1-50
# Trade-off: Higher = more context for LLM, higher latency
BOOKS_PER_RESULT=5

# Minimum cosine similarity for book content chunks
# Range: 0.0-1.0
# Higher = stricter matching, fewer results
# Typical: 0.2 (loose) to 0.7 (strict)
SIMILARITY_THRESHOLD=0.3

# Minimum similarity for attribute-based filters (authors, genres, etc.)
# Typically higher than SIMILARITY_THRESHOLD
FILTER_SIMILARITY_THRESHOLD=0.65

# Maximum number of unique books to retrieve across all filters
# Range: 1-1000
# Higher = more comprehensive search, more resources
MAX_BOOK_IDS=300

# Maximum number of text chunks (excerpts) per book
# Range: 1-20
MAX_CHUNKS_TO_USE=6

# Maximum chunks per book to use in context
MAX_CHUNKS_PER_BOOK=3

# Default number of books for "show more" pagination requests
DEFAULT_SHOW_MORE_LENGTH=3

# Maximum total books to store in session pagination context
MAX_SHOW_MORE_BOOKS=20

################################################################################
# SCORING CONFIGURATION
################################################################################

# IMPORTANT: These three weights MUST sum to 1.0 (±0.01)
# Formula: Final Score = (context × S_sim) + (document × S_doc) + (keyword × S_key)

# Weight for semantic similarity scoring
# Default: 0.45 (45% of final score)
CONTEXT_WEIGHT_SCORE=0.45

# Weight for document overlap/filter density scoring
# Default: 0.25 (25% of final score)
DOCUMENT_WEIGHT_SCORE=0.25

# Weight for keyword/n-gram frequency scoring
# Default: 0.30 (30% of final score)
KEYWORD_WEIGHT_SCORE=0.30

# NOTE: Verify weights sum: 0.45 + 0.25 + 0.30 = 1.00 ✓

################################################################################
# TABLE NAMES CONFIGURATION
################################################################################

# Session context table for pagination and state management
SESSION_CONTEXT_TABLE=book_retrieved_document_details

# Book summary information table
BOOK_SUMMARY_TABLE=book_summary_backup_2

# Chunked book content table (for semantic search)
BOOK_CONTENT_TABLE=book_content_chunked_backup_2

# Book metadata table
BOOK_METADATA_TABLE=book_metadata_backup_2

################################################################################
# CITATION AND VERIFICATION CONFIGURATION
################################################################################

# Maximum number of parallel threads for citation verification
# Range: 1-50
# Higher = faster verification, higher resource usage
MAX_WORKERS_FOR_CITATION_GENERATION=10

# Number of retry attempts for failed citation verification
# Range: 0-3
CITATION_VERIFICATION_RETRY_ATTEMPTS=1

################################################################################
# OPTIONAL: EMBEDDING CONFIGURATION
################################################################################

# Embedding model to use for semantic search
# Options: text-embedding-004, text-embedding-003
EMBEDDING_MODEL=text-embedding-004

# Embedding vector dimensions
EMBEDDING_DIMENSIONS=1536

# Vertex AI location for embedding API
VERTEX_AI_LOCATION=us-central1

################################################################################
# OPTIONAL: ADVANCED CONFIGURATION
################################################################################

# ID per filter strategy for retrieval
# Options: "dynamic" (default), "fixed"
# dynamic: min(ceil(max_ids / filters), 15)
# fixed: always 15 per filter
IDS_PER_FILTER_STRATEGY=dynamic

# Enable response generation from documents (vs. LLM generation)
GENERATE_RESPONSE_FROM_DOCS=false

# Show thinking headers in responses (debugging)
SHOW_HEADERS=false

# Smart response adjustment toggle
SMART_RESPONSE_ADJUSTMENT=true

################################################################################
# PROFILE CONFIGURATIONS (copy one of these based on your scenario)
################################################################################

# LOCAL DEVELOPMENT PROFILE
# Uncomment these overrides for local development:
# FLASK_ENV=development
# LOG_LEVEL=DEBUG
# SIMILARITY_THRESHOLD=0.2
# MAX_BOOK_IDS=50

# PRODUCTION PROFILE
# Uncomment these overrides for production:
# FLASK_ENV=production
# LOG_LEVEL=INFO
# SIMILARITY_THRESHOLD=0.5
# MAX_BOOK_IDS=300
# WORKER_COUNT=9
# WORKER_THREADS_COUNT=4

# HIGH PERFORMANCE PROFILE
# Uncomment these overrides for maximum throughput:
# BOOKS_PER_RESULT=3
# MAX_CHUNKS_TO_USE=3
# MAX_WORKERS_FOR_CITATION_GENERATION=20
# WORKER_THREADS_COUNT=4
# WORKER_TIMEOUT=60

# COST OPTIMIZED PROFILE
# Uncomment these overrides for minimum cost:
# LLM_MAX_TOKENS=512
# BOOKS_PER_RESULT=3
# SIMILARITY_THRESHOLD=0.6
# WORKER_COUNT=2
# WORKER_THREADS_COUNT=1

################################################################################
# SETUP INSTRUCTIONS
################################################################################

# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Edit .env with your actual values (see comments above)
#
# 3. Validate configuration:
#    python -c "import Config; Config.validate_configuration()"
#
# 4. Start the agent:
#    python run.py
#
# 5. Test health check:
#    curl http://localhost:5000/utility/book-content-rag-agent/health
#
# See DEVELOPER_GUIDE.md for detailed setup instructions.
# See CONFIG_REFERENCE.md for detailed parameter documentation.

