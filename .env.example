# Book Finder Agent Environment Configuration
# Copy this file to .env and fill in actual values for your deployment

# =============================================================================
# FLASK & SERVER CONFIGURATION
# =============================================================================
FLASK_ENV=development
FLASK_DEBUG=False
SECRET_KEY=your-secret-key-change-in-production
HOST=0.0.0.0
PORT=5000
WORKERS=4

# =============================================================================
# GOOGLE CLOUD CONFIGURATION
# =============================================================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_CREDENTIALS_PATH=/path/to/credentials.json
GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# =============================================================================
# DATABASE CONFIGURATION (PostgreSQL + pgvector)
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=book_finder_db
DB_USER=postgres
DB_PASSWORD=your-secure-password
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# =============================================================================
# REDIS CONFIGURATION (Cache & Session State)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_POOL_SIZE=10

# =============================================================================
# LLM API KEYS (Fill in for your chosen providers)
# =============================================================================
# OpenAI (for GPT-4, GPT-3.5)
OPENAI_API_KEY=sk-your-openai-key

# Anthropic (for Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Google Generative AI (for Gemini)
GOOGLE_GENAI_API_KEY=your-google-genai-key

# =============================================================================
# LLM CONFIGURATION
# =============================================================================
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# =============================================================================
# EMBEDDING CONFIGURATION
# =============================================================================
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# =============================================================================
# SEMANTIC SEARCH CONFIGURATION
# =============================================================================
DEFAULT_SIMILARITY_THRESHOLD=0.3
SIMILARITY_THRESHOLD=0.3
FILTER_SIMILARITY_THRESHOLD=0.65

# =============================================================================
# AGENT BEHAVIOR CONFIGURATION
# =============================================================================
# Result limits
BOOKS_PER_RESULT=5
MAX_BOOKS_PER_RESPONSE=3
MAX_EXCERPTS_PER_BOOK=5
MAX_BOOK_IDS=300
DEFAULT_SHOW_MORE_LENGTH=3
MAX_SHOW_MORE_BOOKS=20

# Scoring weights (sum should equal 1.0 for normalized weighting)
CONTEXT_WEIGHT_SCORE=0.5
DOCUMENT_WEIGHT_SCORE=0.2
KEYWORD_WEIGHT_SCORE=0.3
CHUNK_RETRIEVAL_DOCUMENT_BOOST=0.2

# Row reduction configuration
REDUCE_BOOKS_ROWS_THRESHOLD=0.3
MIN_DOCUMENTS_TO_SHORTLIST=8

# =============================================================================
# DATABASE TABLE NAMES (Customize if using different schemas)
# =============================================================================
BOOK_TABLE=book_metadata_v2
BOOK_AUTHOR_TABLE=book_author_v2
BOOK_AUTHOR_NORMALIZED_TABLE=book_author_normalized
BOOK_GENRE_TABLE=book_genre_v2
BOOK_AWARD_TABLE=book_award_v2
BOOK_EXCERPT_TABLE=book_excerpts_v2
BOOK_PUBLISHER_TABLE=book_publisher
CONTEXT_TABLE=book_retrieved_document_details
ORGANIZATION_TABLE=book_publisher

# =============================================================================
# FEATURE FLAGS
# =============================================================================
GENERATE_RESPONSE_FROM_DOCS=True
SMART_RESPONSE_ADJUSTMENT=True
SHOW_HEADERS=False

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
GOOGLE_CLOUD_LOGGING=True

# =============================================================================
# SESSION MANAGEMENT
# =============================================================================
SESSION_EXPIRATION_DAYS=30
SESSION_CLEANUP_INTERVAL_HOURS=24

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_RATE_LIMIT=100
API_TIMEOUT=30
API_MAX_PAYLOAD_SIZE=10485760

# =============================================================================
# FALLBACK MESSAGES (Customize these for your use case)
# =============================================================================
FALLBACK_RESPONSE=I could not find matching book details right now. Please try with different keywords or filters.
DEFAULT_MESSAGE_FOR_EMPTY_LLM_CONTEXT=No books were found matching your search criteria for {filter_type}. Please try adjusting your filters or search terms.

# =============================================================================
# PUBLISHER FILTER NAMES (Comma-separated list)
# =============================================================================
ORGANIZATION_NAMES=HarperCollins,Penguin Random House,Simon & Schuster,Hachette Book Group,Macmillan Publishers

